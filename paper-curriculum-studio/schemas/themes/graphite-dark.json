{
  "id": "graphite-dark",
  "label": "Graphite",
  "appearance": "dark",
  "description": "Neutral graphite UI—single violet accent, minimal chroma.",
  "css": {
    "--cur-bg-app": "#121214",
    "--cur-bg-elevated": "#1a1a1f",
    "--cur-bg-subtle": "#24242c",
    "--cur-bg-canvas": "#0b0b0d",
    "--cur-text-primary": "#ececf1",
    "--cur-text-secondary": "#9b9ba3",
    "--cur-text-tertiary": "#6e6e78",
    "--cur-border": "#2f2f38",
    "--cur-border-strong": "#45454f",
    "--cur-accent": "#a78bfa",
    "--cur-accent-muted": "rgba(167, 139, 250, 0.14)",
    "--cur-focus-ring": "rgba(167, 139, 250, 0.5)",
    "--cur-success": "#4ade80",
    "--cur-warning": "#fbbf24",
    "--cur-error": "#f87171",
    "--cur-radius-sm": "6px",
    "--cur-radius-md": "10px",
    "--cur-radius-lg": "14px",
    "--cur-font-sans": "system-ui, -apple-system, 'Segoe UI', sans-serif",
    "--cur-font-mono": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace",
    "--cur-shadow-sm": "0 1px 2px rgba(0,0,0,0.5)",
    "--cur-shadow-md": "0 12px 40px rgba(0,0,0,0.55)",
    "--cur-content-max": "72ch",
    "--cur-transition": "150ms ease"
  },
  "three": {
    "background": "#1a1a1f",
    "fog": { "color": "#1a1a1f", "near": 5, "far": 38 },
    "ambientIntensity": 0.22,
    "directionalColor": "#e8e8f0",
    "directionalIntensity": 0.65,
    "directionalPosition": [4, 7, 5],
    "gridColor": "#2f2f38",
    "accentHex": "#a78bfa"
  },
  "manim": {
    "background": "#121214",
    "text": "#ececf1",
    "accent": "#a78bfa",
    "secondary": "#9b9ba3",
    "grid": "#2f2f38",
    "highlight": "#4ade80"
  },
  "matplotlib": {
    "figure.facecolor": "#121214",
    "axes.facecolor": "#1a1a1f",
    "axes.edgecolor": "#2f2f38",
    "text.color": "#ececf1",
    "axes.labelcolor": "#9b9ba3",
    "xtick.color": "#6e6e78",
    "ytick.color": "#6e6e78",
    "grid.color": "#24242c",
    "grid.alpha": "0.9"
  },
  "series_colors": ["#a78bfa", "#4ade80", "#fbbf24", "#38bdf8", "#f87171", "#f472b6"]
}
