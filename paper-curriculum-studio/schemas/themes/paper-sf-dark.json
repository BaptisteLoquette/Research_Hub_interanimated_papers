{
  "id": "paper-sf-dark",
  "label": "Paper · Dark",
  "appearance": "dark",
  "description": "Xcode-like dark canvas with cyan accent—low glare for long sessions.",
  "css": {
    "--cur-bg-app": "#1c1c1e",
    "--cur-bg-elevated": "#2c2c2e",
    "--cur-bg-subtle": "#3a3a3c",
    "--cur-bg-canvas": "#000000",
    "--cur-text-primary": "#f5f5f7",
    "--cur-text-secondary": "#aeaeb2",
    "--cur-text-tertiary": "#8e8e93",
    "--cur-border": "#48484a",
    "--cur-border-strong": "#636366",
    "--cur-accent": "#64d2ff",
    "--cur-accent-muted": "rgba(100, 210, 255, 0.15)",
    "--cur-focus-ring": "rgba(100, 210, 255, 0.55)",
    "--cur-success": "#30d158",
    "--cur-warning": "#ffd60a",
    "--cur-error": "#ff453a",
    "--cur-radius-sm": "6px",
    "--cur-radius-md": "10px",
    "--cur-radius-lg": "14px",
    "--cur-font-sans": "system-ui, -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', sans-serif",
    "--cur-font-mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
    "--cur-shadow-sm": "0 1px 2px rgba(0,0,0,0.45)",
    "--cur-shadow-md": "0 8px 32px rgba(0,0,0,0.55)",
    "--cur-content-max": "72ch",
    "--cur-transition": "160ms ease"
  },
  "three": {
    "background": "#2c2c2e",
    "fog": { "color": "#2c2c2e", "near": 6, "far": 40 },
    "ambientIntensity": 0.28,
    "directionalColor": "#ffffff",
    "directionalIntensity": 0.75,
    "directionalPosition": [5, 9, 7],
    "gridColor": "#48484a",
    "accentHex": "#64d2ff"
  },
  "manim": {
    "background": "#1c1c1e",
    "text": "#f5f5f7",
    "accent": "#64d2ff",
    "secondary": "#8e8e93",
    "grid": "#48484a",
    "highlight": "#30d158"
  },
  "matplotlib": {
    "figure.facecolor": "#1c1c1e",
    "axes.facecolor": "#2c2c2e",
    "axes.edgecolor": "#48484a",
    "text.color": "#f5f5f7",
    "axes.labelcolor": "#aeaeb2",
    "xtick.color": "#8e8e93",
    "ytick.color": "#8e8e93",
    "grid.color": "#3a3a3c",
    "grid.alpha": "0.85"
  },
  "series_colors": ["#64d2ff", "#30d158", "#ffd60a", "#bf5af2", "#ff453a", "#0a84ff"]
}
