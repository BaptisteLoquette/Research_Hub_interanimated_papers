{
  "id": "harbor-dark",
  "label": "Harbor",
  "appearance": "dark",
  "description": "Deep blue-gray harbor with ice-blue accent—spatial diagrams pop.",
  "css": {
    "--cur-bg-app": "#0c1117",
    "--cur-bg-elevated": "#151b24",
    "--cur-bg-subtle": "#1c2430",
    "--cur-bg-canvas": "#070a0e",
    "--cur-text-primary": "#e8eef7",
    "--cur-text-secondary": "#8fa3bf",
    "--cur-text-tertiary": "#5c6b82",
    "--cur-border": "#243044",
    "--cur-border-strong": "#36445c",
    "--cur-accent": "#7dd3fc",
    "--cur-accent-muted": "rgba(125, 211, 252, 0.12)",
